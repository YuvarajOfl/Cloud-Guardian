# App Settings
APP_NAME="InfraSight Auth Backend"
APP_ENV="development"
PORT=8000

# Database Settings (Assumes MySQL default locally, falls back to SQLite internally if unavailable)
DB_USER="your_db_user_here"
DB_PASSWORD="your_db_password_here"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="infrasight"

# Authentication Settings
JWT_SECRET="your_jwt_secret_here"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth Client Credentials
# Create yours in Google Cloud Console and paste it here
GOOGLE_CLIENT_ID="your_google_client_id_here"

# CORS Origins Allowed (comma separated list)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173"

# Admin Auto-Bootstrap Settings
ADMIN_EMAIL="your_admin_email_here"
ADMIN_PASSWORD="your_admin_password_here"
